# ============================================
# VARIABLES DE ENTORNO - Frontend React/Vite
# Sistema de Farmacia Penitenciaria
# ============================================
# Copiar este archivo a .env.local para desarrollo
# Copiar a .env.production para producción

# ============================================
# CONFIGURACIÓN DE API (REQUERIDA)
# ============================================

# URL base de la API del backend Django
# En desarrollo: http://localhost:8000/api
# En producción: https://tu-dominio.com/api
VITE_API_URL=http://localhost:8000/api

# Versión de API esperada (default: v1)
# Se usa para verificar compatibilidad con el backend
VITE_API_VERSION=v1

# Permitir conexiones HTTP no seguras (solo para staging/desarrollo)
# En producción SIEMPRE debe ser false o no definido
# VITE_ALLOW_INSECURE_HTTP=false

# ============================================
# CONFIGURACIÓN DE HEALTHCHECK
# ============================================

# Habilitar verificación de salud del API al iniciar
# Default: true
VITE_ENABLE_HEALTHCHECK=true

# Timeout para healthcheck en milisegundos
# Default: 5000 (5 segundos)
VITE_HEALTHCHECK_TIMEOUT=5000

# Ruta del endpoint de healthcheck
# Cambiar si el backend expone health en otra ruta
# Default: /health/
VITE_HEALTH_ENDPOINT=/health/

# Modo solo autenticación (sin healthcheck)
# Útil cuando el backend no implementa endpoint de health
# Default: false
VITE_AUTH_ONLY_MODE=false

# ============================================
# CONFIGURACIÓN DE SESIÓN
# ============================================

# Minutos de inactividad antes de cerrar sesión automáticamente
# Default: 20 minutos
VITE_INACTIVITY_MINUTES=20

# ============================================
# OPCIONES DE DESARROLLO (NO USAR EN PRODUCCIÓN)
# ============================================

# Mostrar botón de login de desarrollo en la página de login
# VITE_SHOW_DEV_LOGIN=false

# Habilitar endpoint de autologin de desarrollo
# VITE_ENABLE_DEV_LOGIN=false

# Usar datos mock en lugar de llamadas reales al API
# VITE_USE_MOCK_DATA=false

# Mostrar botones de usuarios de prueba en login
# VITE_SHOW_TEST_USER_BUTTONS=false

# ============================================
# SUPABASE (OPCIONAL - Deshabilitado por defecto)
# ============================================
# El tema se carga desde la API de Django
# Supabase solo se usa para almacenamiento de logos si está configurado

# URL del proyecto Supabase
# VITE_SUPABASE_URL=https://xxx.supabase.co

# Clave anónima pública de Supabase
# VITE_SUPABASE_ANON_KEY=eyJhbG...

# ============================================
# NOTAS DE SEGURIDAD
# ============================================
# 
# 1. NUNCA incluir secretos en este archivo para producción
# 2. Las variables VITE_* son públicas y visibles en el navegador
# 3. Los tokens JWT se almacenan en memoria (no localStorage)
# 4. El refresh token se maneja via cookie HttpOnly del servidor
# 5. HTTPS es obligatorio en producción (VITE_ALLOW_INSECURE_HTTP=false)
#
# ============================================
