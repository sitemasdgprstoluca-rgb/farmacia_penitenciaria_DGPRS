# Variables de Entorno para Scripts de Infraestructura
# Copia este archivo a .env y configura según tu entorno

# ======================
# BACKUP CONFIGURATION
# ======================

# PostgreSQL
DB_HOST=localhost
DB_USER=postgres
DB_NAME=farmacia
DB_PASSWORD=tu_password_seguro

# Directorios
BACKUP_DIR=/backups/farmacia
PROJECT_ROOT=/var/www/farmacia

# Retención de backups (días)
RETENTION_DAYS=30

# AWS S3 (opcional - comentar si no se usa)
# AWS_S3_BUCKET=farmacia-backups
# AWS_ACCESS_KEY_ID=tu_access_key
# AWS_SECRET_ACCESS_KEY=tu_secret_key

# Test restore
TEST_DB_NAME=farmacia_test_restore

# ======================
# MONITORING (Prometheus/Grafana)
# ======================

# URLs de servicios
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
ALERTMANAGER_URL=http://localhost:9093

# ======================
# ALERTING
# ======================

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#alerts

# PagerDuty (opcional)
# PAGERDUTY_SERVICE_KEY=tu_service_key

# ======================
# LOGGING (ELK Stack)
# ======================

ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601
LOG_DIR=/var/log/farmacia

# ======================
# APLICACIÓN
# ======================

# Django
DJANGO_URL=http://localhost:8000
REDIS_URL=redis://localhost:6379/1

# ======================
# RENDER.COM ESPECÍFICO
# ======================
# (Estas las configuras en el dashboard de Render)

# DATABASE_URL=postgresql://...  (Render lo proporciona)
# REDIS_URL=redis://...          (Si usas Redis add-on)
