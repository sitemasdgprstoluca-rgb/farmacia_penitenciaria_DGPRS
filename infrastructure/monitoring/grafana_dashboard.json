{
  "dashboard": {
    "title": "Farmacia Production",
    "description": "Production monitoring dashboard",
    "tags": ["production", "farmacia"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "API Request Rate",
        "targets": [
          {
            "expr": "rate(django_http_requests_total[5m])"
          }
        ],
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8}
      },
      {
        "id": 2,
        "title": "Error Rate",
        "targets": [
          {
            "expr": "rate(django_http_errors_total[5m])"
          }
        ],
        "type": "graph",
        "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8}
      },
      {
        "id": 3,
        "title": "Database Connections",
        "targets": [
          {
            "expr": "pg_stat_activity_count"
          }
        ],
        "type": "gauge",
        "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8}
      },
      {
        "id": 4,
        "title": "API Latency (P95)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, django_http_request_duration_seconds)"
          }
        ],
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 8, "h": 8}
      },
      {
        "id": 5,
        "title": "Memory Usage",
        "targets": [
          {
            "expr": "node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes"
          }
        ],
        "type": "gauge",
        "gridPos": {"x": 8, "y": 8, "w": 8, "h": 8}
      },
      {
        "id": 6,
        "title": "Disk Usage",
        "targets": [
          {
            "expr": "node_filesystem_used_bytes / node_filesystem_size_bytes"
          }
        ],
        "type": "gauge",
        "gridPos": {"x": 16, "y": 8, "w": 8, "h": 8}
      }
    ]
  }
}
