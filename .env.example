# Django
SECRET_KEY=django-insecure-generated-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=farmacia.midominio.com,www.farmacia.midominio.com

# Base de datos (usar DATABASE_URL en produccion)
DATABASE_URL=postgresql://usuario:password@localhost:5432/farmacia
DB_CONN_MAX_AGE=600
# Opcional (solo desarrollo): habilitar SQLite
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# CORS / CSRF (poner el dominio real con https)
CORS_ORIGINS=https://farmacia.midominio.com
CSRF_ORIGINS=https://farmacia.midominio.com

# JWT
JWT_SECRET=your-jwt-secret-key

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Redis (opcional)
REDIS_URL=redis://localhost:6379/0

# Produccion/seguridad
ENFORCE_HTTPS=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/farmacia/django.log
