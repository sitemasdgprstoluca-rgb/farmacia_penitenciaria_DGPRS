# =============================================================================
# CONFIGURACIÓN DE PRODUCCIÓN - FARMACIA PENITENCIARIA
# =============================================================================
# IMPORTANTE: NO USAR VALORES POR DEFECTO EN PRODUCCIÓN
# Generar valores seguros y configurarlos en el panel de Render/servidor

# SEGURIDAD
# Generar con: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=CHANGE-THIS-TO-A-REAL-SECRET-KEY-IN-PRODUCTION-min-50-chars

# MODO DEBUG (SIEMPRE False en producción)
DEBUG=False

# HOSTS PERMITIDOS (separados por coma, sin espacios)
# Ejemplo: farmacia.example.com,www.farmacia.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# BASE DE DATOS
# =============================================================================
# PostgreSQL en Render/Supabase (obligatorio en producción)
# Formato: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/farmacia_db

# Opciones adicionales de base de datos
DB_CONN_MAX_AGE=600
DB_POOL_SIZE=10

# =============================================================================
# CORS Y SEGURIDAD
# =============================================================================
# Origenes permitidos para CORS (separados por coma)
# Ejemplo: https://farmacia.example.com,https://app.farmacia.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Dominios de cookies seguros (sin http://)
CSRF_TRUSTED_ORIGINS=https://farmacia.example.com

# =============================================================================
# JWT
# =============================================================================
JWT_ACCESS_TOKEN_LIFETIME_HOURS=24
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# =============================================================================
# SEGURIDAD HTTPS
# =============================================================================
# Forzar HTTPS (True en producción)
ENFORCE_HTTPS=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# =============================================================================
# CACHE (Redis recomendado en producción)
# =============================================================================
# Redis URL (opcional pero recomendado)
# REDIS_URL=redis://localhost:6379/0
CACHE_URL=redis://localhost:6379/1

# =============================================================================
# EMAIL
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@farmacia.gob.mx

# =============================================================================
# CAPTCHA (reCAPTCHA)
# =============================================================================
# Habilita validaci�n de reCAPTCHA en login y formularios p�blicos
RECAPTCHA_ENABLED=False
RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
# En Render usar stdout, no archivos
LOG_TO_STDOUT=True

# =============================================================================
# OBSERVABILIDAD (Opcional)
# =============================================================================
# Sentry para monitoreo de errores
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=production
