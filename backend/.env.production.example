# ══════════════════════════════════════════════════════════════════════════════
# FARMACIA PENITENCIARIA - CONFIGURACIÓN DE PRODUCCIÓN
# ══════════════════════════════════════════════════════════════════════════════
# IMPORTANTE: Copia este archivo como .env y configura los valores reales
# NUNCA subas el archivo .env con valores reales al repositorio
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# DJANGO CORE
# ─────────────────────────────────────────────────────────────────────────────
# Genera una nueva SECRET_KEY con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CAMBIAR_POR_CLAVE_SECRETA_UNICA_DE_50_CARACTERES

# NUNCA usar DEBUG=True en producción
DEBUG=False

# Lista de dominios permitidos (separados por coma, sin espacios)
# Ejemplo: farmacia.gobierno.mx,www.farmacia.gobierno.mx,192.168.1.100
ALLOWED_HOSTS=TU_DOMINIO.com,www.TU_DOMINIO.com

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS - PostgreSQL recomendado para producción
# ─────────────────────────────────────────────────────────────────────────────
# Formato: postgres://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
DATABASE_URL=postgres://farmacia_user:CONTRASEÑA_SEGURA@localhost:5432/farmacia_penitenciaria

# ─────────────────────────────────────────────────────────────────────────────
# CORS Y CSRF - URLs del frontend
# ─────────────────────────────────────────────────────────────────────────────
# URLs exactas del frontend (con https:// en producción)
CORS_ALLOWED_ORIGINS=https://TU_DOMINIO.com,https://www.TU_DOMINIO.com
CSRF_TRUSTED_ORIGINS=https://TU_DOMINIO.com,https://www.TU_DOMINIO.com

# ─────────────────────────────────────────────────────────────────────────────
# SEGURIDAD HTTPS - Activar en producción con certificado SSL
# ─────────────────────────────────────────────────────────────────────────────
ENFORCE_HTTPS=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ─────────────────────────────────────────────────────────────────────────────
# THROTTLING - Límites de tasa para protección contra abuso
# ─────────────────────────────────────────────────────────────────────────────
# Formato: número/periodo (second, minute, hour, day)
# Usuarios anónimos - más restrictivo
THROTTLE_RATE_ANON=100/hour

# Usuarios autenticados - según rol
THROTTLE_RATE_USER=1000/hour
THROTTLE_RATE_FARMACIA=2000/hour
THROTTLE_RATE_ADMIN=5000/hour

# Endpoints de login - protección contra fuerza bruta
THROTTLE_RATE_LOGIN=5/minute

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=WARNING

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (opcional - para notificaciones)
# ─────────────────────────────────────────────────────────────────────────────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu_correo@gmail.com
# EMAIL_HOST_PASSWORD=contraseña_de_aplicacion

# ─────────────────────────────────────────────────────────────────────────────
# BACKUP (opcional)
# ─────────────────────────────────────────────────────────────────────────────
# BACKUP_DIR=/var/backups/farmacia
# BACKUP_RETENTION_DAYS=30
