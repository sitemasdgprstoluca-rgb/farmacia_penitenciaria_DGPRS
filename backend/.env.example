# ============================================
# FARMACIA PENITENCIARIA - VARIABLES DE ENTORNO
# ============================================
# Copiar este archivo como .env y configurar los valores

# Django Core Settings
# --------------------
# CRÍTICO: Generar una clave secreta única y segura para producción
# Puede generarse con: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION-abc123xyz789

# Modo debug (True para desarrollo, False para producción)
DEBUG=True

# Hosts permitidos (separados por coma)
# Ejemplo producción: ALLOWED_HOSTS=farmacia.ejemplo.com,www.farmacia.ejemplo.com
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Settings
# -----------------
# Por defecto usa SQLite. Para PostgreSQL/MySQL/Supabase usar formato DATABASE_URL
# Ejemplo PostgreSQL: DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/farmacia_db
# Ejemplo Supabase: DATABASE_URL=postgresql://postgres:[PASSWORD]@db.XXXX.pooler.supabase.net:6543/postgres
# Ejemplo MySQL: DATABASE_URL=mysql://usuario:contraseña@localhost:3306/farmacia_db
# Si no se define DATABASE_URL, se usa SQLite por defecto
# DATABASE_URL=sqlite:///db.sqlite3

# CORS Settings
# -------------
# Orígenes permitidos para CORS (separados por coma)
# Ejemplo: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://farmacia.ejemplo.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security Settings (Producción)
# -------------------------------
# Descomentar y configurar para producción
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# Email Settings (Opcional)
# --------------------------
# Para notificaciones por email
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu-email@ejemplo.com
# EMAIL_HOST_PASSWORD=tu-contraseña-de-aplicacion

# Static Files (Producción)
# --------------------------
# STATIC_ROOT=/var/www/farmacia/static/
# MEDIA_ROOT=/var/www/farmacia/media/

# JWT Settings (Opcional - sobreescribir defaults)
# -------------------------------------------------
# ACCESS_TOKEN_LIFETIME_MINUTES=15
# REFRESH_TOKEN_LIFETIME_DAYS=7

# Logging
# -------
# LOG_LEVEL=INFO
# LOG_FILE=/var/log/farmacia/django.log
