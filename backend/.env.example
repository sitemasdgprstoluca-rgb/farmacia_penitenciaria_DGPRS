# ══════════════════════════════════════════════════════════════════════════════
# FARMACIA PENITENCIARIA - VARIABLES DE ENTORNO
# ══════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env y modifica los valores según tu entorno.
# NUNCA subas el archivo .env al repositorio.
#
# INSTRUCCIONES:
# - Para DESARROLLO LOCAL: Descomenta la sección "LOCAL" y comenta "PRODUCCIÓN"
# - Para RENDER/SUPABASE: Descomenta la sección "PRODUCCIÓN" y comenta "LOCAL"
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN BÁSICA
# ─────────────────────────────────────────────────────────────────────────────
# Genera una clave secreta única para producción:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-key-CHANGE-IN-PRODUCTION

# ═══════════════════════════════════════════════════════════════════════════
# ▼▼▼ DESARROLLO LOCAL ▼▼▼
# ═══════════════════════════════════════════════════════════════════════════
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos: Dejar vacío para usar SQLite automáticamente
# DATABASE_URL=

# CORS: Frontend local (Vite usa 5173 por defecto)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Seguridad HTTPS desactivada en local
ENFORCE_HTTPS=False

# ═══════════════════════════════════════════════════════════════════════════
# ▼▼▼ PRODUCCIÓN (RENDER + SUPABASE) ▼▼▼
# ═══════════════════════════════════════════════════════════════════════════
# Descomenta estas líneas y comenta las de arriba para producción:

# DEBUG=False
# ALLOWED_HOSTS=tu-backend.onrender.com

# Base de datos Supabase (obtén la URL en: Supabase > Settings > Database > Connection string > URI)
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# CORS: Frontend en Render
# CORS_ALLOWED_ORIGINS=https://tu-frontend.onrender.com
# CSRF_TRUSTED_ORIGINS=https://tu-frontend.onrender.com,https://tu-backend.onrender.com

# Seguridad HTTPS activada en producción
# ENFORCE_HTTPS=True
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN ADICIONAL (Opcional)
# ─────────────────────────────────────────────────────────────────────────────
# Rate limiting - Ajustar según tráfico esperado
# Desarrollo local:
THROTTLE_RATE_ANON=200/hour
THROTTLE_RATE_USER=1000/hour
THROTTLE_RATE_IMPORT=50/day

# Producción (valores recomendados):
# THROTTLE_RATE_ANON=500/hour
# THROTTLE_RATE_USER=5000/hour
# THROTTLE_RATE_IMPORT=20/day

# Duración de tokens JWT
JWT_ACCESS_TOKEN_LIFETIME_HOURS=1
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Logging
LOG_LEVEL=INFO
# LOG_FILE=  # Dejar vacío para usar el predeterminado

# Conexiones DB (para producción)
DB_CONN_MAX_AGE=600
